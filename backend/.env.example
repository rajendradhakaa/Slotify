# Backend Environment Variables Template

# DATABASE CONFIGURATION
# Development: Local MySQL
# Production: Cloud MySQL (AWS RDS, DigitalOcean, PlanetScale, etc.)
DATABASE_URL=mysql+pymysql://user:password@host:3306/database_name

# EMAIL CONFIGURATION (Gmail or custom SMTP)
# For Gmail: Use App Password (not your actual Gmail password)
# 1. Enable 2-Step Verification
# 2. Generate App Password: https://myaccount.google.com/apppasswords
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# FRONTEND URL - For CORS configuration
# Development: http://localhost:5173
# Production: https://your-frontend-domain.com
FRONTEND_URL=http://localhost:5173

# BACKEND URL - For reference and email links
# Development: http://localhost:8000
# Production: https://api.your-domain.com
BACKEND_URL=http://localhost:8000

# ENVIRONMENT - Determines app behavior
# Values: development, production, staging
ENVIRONMENT=development

# DEBUG MODE - Enable detailed error messages
# NEVER set to True in production
DEBUG=True

# OAUTH PROVIDER REDIRECT URLS
# Set these to your provider authorization URLs (or auth gateway endpoints)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
OAUTH_GOOGLE_URL=
OAUTH_GITHUB_URL=
